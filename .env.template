# ─────────────────────────────────────────────────────────────────────────────
# Kinetic-Core Environment Configuration Template
# Copy to .env and fill in your Azure resource values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_ADA=text-embedding-ada-002

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_KEY=<your-search-admin-key>
AZURE_SEARCH_INDEX=kinetic-core-manuals

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-key>
COSMOS_DB=kinetic-core

# ── Azure IoT Hub ─────────────────────────────────────────────────────────────
IOTHUB_CONNECTION_STRING=HostName=<iothub>.azure-devices.net;SharedAccessKeyName=iothubowner;SharedAccessKey=<key>
IOTHUB_DEVICE_CONNECTION_STRING=HostName=<iothub>.azure-devices.net;DeviceId=KCX-NYC-0042;SharedAccessKey=<device-key>

# ── Kinetic-Core API ──────────────────────────────────────────────────────────
KINETIC_CORE_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# ── Monitoring ────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<your-webhook>
BASELINE_F1_SCORE=0.91
DRIFT_THRESHOLD=0.05

# ── Azure Deployment (CI/CD) ──────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-service-principal-client-id>
AZURE_RG=kinetic-core-rg
FUNCTION_APP_NAME=<your-function-app-name>
